{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "name": "centro-salud-turnos",

  "buildCommand": "bash vercel_build.sh",

  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/api/index",
      "headers": { "cache-control": "public, max-age=31536000, immutable" }
    },
    {
      "src": "/(.*)",
      "dest": "/api/index"
    }
  ]
}
